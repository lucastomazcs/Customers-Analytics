{
  "name": "Customer Analytics 360 Theme",
  "dataColors": [
    "#1F3A5F",
    "#4C78A8",
    "#72B7B2",
    "#F2CF5B",
    "#D9534F",
    "#8E8E8E"
  ],
  "background": "#F7F7F7",
  "foreground": "#1F2933",
  "tableAccent": "#1F3A5F",
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": false
          }
        ],
        "visualHeader": [
          {
            "show": false
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#1F2933"
              }
            },
            "fontSize": 12,
            "fontFamily": "Segoe UI",
            "alignment": "left"
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#1F3A5F"
              }
            },
            "fontSize": 24,
            "fontFamily": "Segoe UI"
          }
        ],
        "categoryLabels": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#4F4F4F"
              }
            },
            "fontSize": 10
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "items": [
          {
            "fontColor": {
              "solid": {
                "color": "#1F2933"
              }
            },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ],
        "header": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#1F2933"
              }
            },
            "fontSize": 10
          }
        ]
      }
    }
  }
}